# =============================================================================
# COOLIFY DEPLOYMENT - Environment Variables
# =============================================================================
# Configure these in your Coolify project under "Environment Variables"
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL with pgvector)
# -----------------------------------------------------------------------------
# If using Coolify PostgreSQL service, these will be auto-filled
# Otherwise, set your external PostgreSQL URL
DATABASE_URL=postgresql://anoda:password@db:5432/anoda_facematch?schema=public

# Database container environment (if using docker-compose DB)
POSTGRES_USER=anoda
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=anoda_facematch

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# If using Coolify Redis service, this will be auto-filled
# Otherwise, set your external Redis URL
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=production
APP_NAME=Anoda Facematch

# -----------------------------------------------------------------------------
# Security (IMPORTANT: Change these!)
# -----------------------------------------------------------------------------
SESSION_SECRET=generate-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=generate-a-long-random-32-character-key

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
# PORT=3005 (internal - don't expose)
# ELYSIA_PORT=3005 (internal)
BASE_API_URL=https://your-coolify-url.coolify.io

# -----------------------------------------------------------------------------
# AI Service (internal Docker network)
# -----------------------------------------------------------------------------
AI_SERVICE_URL=http://ai_service:8000

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_REGION=auto

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Client
# -----------------------------------------------------------------------------
VITE_API_URL=https://your-coolify-url.coolify.io
API_TARGET=http://api:3005

# -----------------------------------------------------------------------------
# Sentry (Observability)
# -----------------------------------------------------------------------------
# Create a project at https://sentry.io and get your DSN
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =============================================================================
# COOLIFY SETUP STEPS
# =============================================================================

# 1. CREATE PROJECT
#    - Log in to Coolify
#    - Create a new Project
#    - Add a "Docker Compose" resource

# 2. CONFIGURE DOCKER COMPOSE
#    - Source: Your Git repository
#    - Docker Compose file: docker-compose.yml
#    - Set the environment variables above in the Coolify UI

# 3. CONFIGURE CLIENT (Static App)
#    - Add a new "Static" resource
#    - Source: Your Git repository
#    - Build Command: bun run build
#    - Output Directory: dist
#    - Port: 5173
#    - Set VITE_API_URL and VITE_SENTRY_DSN environment variables

# 4. CONFIGURE DOMAIN (Optional)
#    - Go to the client resource settings
#    - Add your custom domain
#    - Coolify will handle SSL automatically

# =============================================================================
# R2 CORS SETUP (Cloudflare Dashboard)
# =============================================================================

# 1. Go to Cloudflare Dashboard > R2 > Manage API Tokens
# 2. Create a token with:
#    - Permissions: Admin read/write
#    - TTL: Permanent (or as needed)
# 3. Copy the token to R2_SECRET_ACCESS_KEY in Coolify

# 4. Go to R2 > Settings > CORS Policy
# 5. Add this policy:
# [
#   {
#     "AllowedOrigins": ["https://your-coolify-url.coolify.io"],
#     "AllowedMethods": ["GET", "PUT", "POST", "DELETE", "HEAD"],
#     "AllowedHeaders": ["*"]
#   }
# ]

# =============================================================================

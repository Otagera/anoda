# =============================================================================
# COOLIFY DEPLOYMENT - Environment Variables
# =============================================================================
# Use these values when configuring your Coolify project.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=production
APP_NAME=Anoda Facematch

# -----------------------------------------------------------------------------
# Database & Redis (if using Coolify services, values will be auto-filled)
# -----------------------------------------------------------------------------
# DATABASE_URL will be provided by Coolify PostgreSQL service
# REDIS_URL will be provided by Coolify Redis service

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
# PORT=3005 (internal)
# ELYSIA_PORT=3005 (internal)
SESSION_SECRET=generate-a-long-random-string-here
BASE_API_URL=https://your-coolify-url.coolify.io

# -----------------------------------------------------------------------------
# AI Service (internal Docker network)
# -----------------------------------------------------------------------------
AI_SERVICE_URL=http://ai_service:8000

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_REGION=auto

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Encryption (IMPORTANT: Change this!)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=generate-a-long-random-32-character-key

# -----------------------------------------------------------------------------
# Client
# -----------------------------------------------------------------------------
VITE_API_URL=https://your-coolify-url.coolify.io
API_TARGET=http://api:3005

# -----------------------------------------------------------------------------
# Sentry (Observability)
# -----------------------------------------------------------------------------
# Create a project at https://sentry.io and get your DSN
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =============================================================================
# COOLIFY SETUP STEPS
# =============================================================================
# 
# 1. Create a new Project in Coolify
#
# 2. Add a "Docker Compose" resource with these services:
#    - db (PostgreSQL with pgvector)
#    - redis
#    - api
#    - worker
#    - ai_service
#
# 3. Configure environment variables in Coolify UI
#
# 4. Deploy the API stack
#
# 5. Add a "Static" resource for the client:
#    - Build Pack: Static
#    - Build Command: npm run build (or bun run build)
#    - Output Directory: dist
#    - Port: 5173
#
# 6. Configure the client environment variables
#
# =============================================================================
# R2 CORS SETUP
# =============================================================================
# Go to Cloudflare Dashboard > R2 > Manage API Tokens
# Create a token with Object Read & Write permissions
#
# In R2 Dashboard > Settings > CORS Policy, add:
# [
#   {
#     "AllowedOrigins": ["https://your-coolify-url.coolify.io"],
#     "AllowedMethods": ["GET", "PUT", "POST", "DELETE"],
#     "AllowedHeaders": ["*"]
#   }
# ]
# =============================================================================

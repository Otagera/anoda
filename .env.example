# =============================================================================
# ANODA FACEMATCH - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Values shown with || are defaults used if the variable is not set.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Anoda Facematch

# -----------------------------------------------------------------------------
# Database (PostgreSQL with pgvector)
# -----------------------------------------------------------------------------
# Full connection URL (recommended - overrides individual settings below)
DATABASE_URL=postgresql://anoda:password@localhost:5432/anoda_facematch?schema=public
DB_URL=postgresql://anoda:password@localhost:5432/
DB_NAME=anoda_facematch

# Individual DB settings (optional if DATABASE_URL is set)
PG_USERNAME=anoda
PG_HOSTNAME=localhost
PG_DATABASE=anoda_facematch
PG_PASSWORD=password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOSTNAME=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
PORT=5001
ELYSIA_PORT=3005
SESSION_SECRET=your-secret-key-here-change-in-production
BASE_API_URL=http://localhost

# -----------------------------------------------------------------------------
# AI Service (Python)
# -----------------------------------------------------------------------------
AI_SERVICE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_REGION=auto

# -----------------------------------------------------------------------------
# Logging (Pino)
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Chatterbox (Structured Logging Service)
# -----------------------------------------------------------------------------
CHATTERBOX_API_URL=http://localhost:3005
CHATTERBOX_APP_NAME=anoda
CHATTERBOX_API_SECRET=your-chatterbox-api-secret
LOGGING_API_URL=
BULK_LOGGING_API_URL=
LOG_FILE=logQueue.json
RETRY_DELAY_MS=10000
MAX_BULK_LOG=10

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# -----------------------------------------------------------------------------
# Client (Vite)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3005
API_TARGET=http://localhost:3005

# -----------------------------------------------------------------------------
# Test Environment (optional - override above for testing)
# -----------------------------------------------------------------------------
TEST_DB_URL=postgresql://anoda:password@localhost:5432/
TEST_DB_NAME=anoda_facematch_test
TEST_PORT=5001
TEST_ELYSIA_PORT=3005
TEST_SESSION_SECRET=test-secret
TEST_REDIS_PORT=6379
TEST_REDIS_HOSTNAME=localhost
TEST_REDIS_USERNAME=default
TEST_REDIS_PASSWORD=
TEST_REDIS_URL=redis://localhost:6379
TEST_AI_SERVICE_URL=http://localhost:8000
TEST_BASE_API_URL=http://localhost

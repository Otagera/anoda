generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model album_images {
  album_images_id String @id @default(uuid()) @db.Uuid
  album_id        String @db.Uuid
  image_id        String @db.Uuid
  albums          albums @relation(fields: [album_id], references: [album_id], onDelete: Cascade)
  images          images @relation(fields: [image_id], references: [image_id], onDelete: Cascade)

  @@unique([album_id, image_id])
}

model album_members {
  id           String    @id @default(uuid()) @db.Uuid
  album_id     String    @db.Uuid
  user_id      String?   @db.Uuid
  role         String    @default("VIEWER") // VIEWER, CONTRIBUTOR, ADMIN
  passcode     String?
  invite_token String?   @unique
  expires_at   DateTime? @db.Timestamptz(6) // Invite expiry (default: 7 days)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  album albums @relation(fields: [album_id], references: [album_id], onDelete: Cascade)
  user  users? @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model albums {
  album_id          String                @id @default(uuid()) @db.Uuid
  album_name        String?
  created_by        String?               @db.Uuid
  storage_config_id String?               @db.Uuid
  cover_image_id    String?               @db.Uuid
  creation_date     DateTime?             @default(now()) @db.Timestamptz(6)
  shared_link       String?
  share_token       String?               @unique
  deleted_at        DateTime?             @db.Timestamptz(6)
  album_images      album_images[]
  album_members     album_members[]
  webhook_events    webhook_events[]
  users             users?                @relation(fields: [created_by], references: [user_id], onDelete: SetNull)
  cover_image       images?               @relation("AlbumCover", fields: [cover_image_id], references: [image_id], onDelete: SetNull)
  storage_config    user_storage_configs? @relation(fields: [storage_config_id], references: [id], onDelete: SetNull)
  settings          album_settings?
}

model album_settings {
  album_id            String    @id @db.Uuid
  is_event            Boolean   @default(false)
  requires_approval   Boolean   @default(true)
  tagging_policy      String    @default("HOST_ONLY") // HOST_ONLY, GUESTS_SELF, ANYONE
  expires_at          DateTime? @db.Timestamptz(6)
  allow_guest_uploads Boolean   @default(false)
  webhook_url         String?
  album               albums    @relation(fields: [album_id], references: [album_id], onDelete: Cascade)
}

model faces {
  face_id        Int             @id @default(autoincrement())
  image_id       String?         @db.Uuid
  embedding      Float[]         @db.Real
  bounding_box   Json?
  processed_time DateTime?       @default(now()) @db.Timestamptz(6)
  person_id      String?         @db.Uuid
  images         images?         @relation(fields: [image_id], references: [image_id], onDelete: SetNull)
  people         people?         @relation(fields: [person_id], references: [person_id], onDelete: SetNull)
  ignored_faces  ignored_faces[]
}

model people {
  person_id     String          @id @default(uuid()) @db.Uuid
  name          String
  user_id       String?         @db.Uuid
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  faces         faces[]
  ignored_faces ignored_faces[]
  users         users?          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model ignored_faces {
  id         Int      @id @default(autoincrement())
  person_id  String   @db.Uuid
  face_id    Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  people     people   @relation(fields: [person_id], references: [person_id], onDelete: Cascade)
  faces      faces    @relation(fields: [face_id], references: [face_id], onDelete: Cascade)

  @@unique([person_id, face_id])
}

model images {
  image_id         String         @id @default(uuid()) @db.Uuid
  image_path       String
  optimized_path   String?
  storage_provider String? // 'local', 'r2', 's3', 'byos'
  storage_key      String? // The key/path in storage provider
  status           String         @default("APPROVED") // PENDING, APPROVED, REJECTED
  upload_date      DateTime?      @default(now()) @db.Timestamptz(6)
  update_date      DateTime?      @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?      @db.Timestamptz(6)
  file_hash        String?
  perceptual_hash  String?
  rejection_reason String?
  album_images     album_images[]
  faces            faces[]
  original_width   Int
  original_height  Int
  size             Int            @default(0)
  optimized_size   Int            @default(0)
  uploaded_by      String?        @db.Uuid
  guest_session_id String?        @db.Uuid
  users            users?         @relation(fields: [uploaded_by], references: [user_id], onDelete: Cascade)
  covered_albums   albums[]       @relation("AlbumCover")
}

model user_storage_configs {
  id                String    @id @default(uuid()) @db.Uuid
  user_id           String    @db.Uuid
  provider          String    @default("r2")
  bucket            String
  endpoint          String
  access_key_id     String
  secret_access_key String
  region            String?   @default("auto")
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  albums            albums[]
  users             users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model usage_logs {
  id         Int      @id @default(autoincrement())
  user_id    String   @db.Uuid
  album_id   String?  @db.Uuid // For storage by album (no relation - just for reference)
  resource   String   // storage, compute
  operation  String   // image_optimization, face_recognition, face_search, face_clustering, bulk_download, file_deletion
  quantity   Int      @default(1)
  metadata   Json?    @default("{}") // Additional details (image_id, etc.)
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model notifications {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  type       String
  is_read    Boolean  @default(false)
  metadata   Json?    @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model webhook_events {
  id         String   @id @default(uuid()) @db.Uuid
  album_id   String   @db.Uuid
  event_type String
  payload    Json?
  status     String   @default("PENDING") // PENDING, SUCCESS, FAILED
  attempts   Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  album albums @relation(fields: [album_id], references: [album_id], onDelete: Cascade)
}

model users {
  user_id           String                 @id @default(uuid()) @db.Uuid
  email             String                 @unique
  password          String
  plan              String                 @default("free") // free, pro
  albums            albums[]
  images            images[]
  people            people[]
  storage_configs   user_storage_configs[]
  usage_logs        usage_logs[]
  album_members     album_members[]
  notifications     notifications[]
  preferences       Json?                  @default("{}")
  email_preferences Json?                  @default("{\"welcome\":true,\"photoApproved\":true,\"clustering\":true,\"marketing\":false}")
  refresh_tokens    refresh_tokens[]
  password_resets   password_resets[]
}

model password_resets {
  id         String   @id @default(uuid()) @db.Uuid
  token      String   @unique
  user_id    String   @db.Uuid
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model refresh_tokens {
  id         String   @id @default(uuid()) @db.Uuid
  token      String   @unique
  user_id    String   @db.Uuid
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

		"testinit": "NODE_ENV=test bun src/utils/scripts/test/initialize.ts",
		"migrate": "prisma migrate deploy",
		"format": "bunx biome format --write \"src/**/*.{ts,tsx}\"",
		"lint": "bunx biome lint ./src",
		"check": "bunx biome check"
	},

